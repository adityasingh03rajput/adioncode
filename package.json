{
  "name": "letsbunk-server",
  "version": "2.0.0",
  "description": "LetsBunk Enhanced Server v2.0 - Complete Attendance Management System with Advanced Security & Analytics",
  "main": "server-enhanced.js",
  "scripts": {
    "start": "node server-enhanced.js",
    "dev": "nodemon server-enhanced.js",
    "cloud": "node server-cloud.js",
    "enhanced": "node server-enhanced.js",
